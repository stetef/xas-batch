# Copy to .env and edit. Consumed by `xas-batch-tree`.

# Required: root directory scanned recursively for *.bcr.combined files.
XAS_INPUT_ROOT=/Users/username/data/combined-files-2026-05-29_16-15

# Optional: mirror outputs into this dir, preserving the input tree structure.
# Leave unset/blank to write each .npz as a sister file next to its source.
# XAS_OUTPUT_DIR=/Users/username/data/batch-exafs-processing/out

# Optional: SQLite catalog path.
# Default: <XAS_OUTPUT_DIR or XAS_INPUT_ROOT>/xas_catalog.sqlite
# XAS_DB_PATH=/Users/username/data/batch-exafs-processing/out/xas_catalog.sqlite
